@page
@model Learner_Management_System.Pages_AssessmentBanks.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].BankName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].Version)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].CreatedDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].LastModifiedDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].IsActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].Qualification)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].CreatedBy)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AssessmentBank[0].AssessorDeveloper)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.AssessmentBank) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.BankName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Version)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastModifiedDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Qualification.QualificationName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedBy.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AssessorDeveloper.Email)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.AssessmentBankId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.AssessmentBankId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.AssessmentBankId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
