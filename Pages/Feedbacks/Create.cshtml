@page
@model Learner_Management_System.Pages_Feedbacks.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Feedback</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Feedback.LearnerId" class="control-label"></label>
                <select asp-for="Feedback.LearnerId" class ="form-control" asp-items="ViewBag.LearnerId" aria-required="true"></select>
            </div>
            <div class="form-group">
                <label asp-for="Feedback.TeacherId" class="control-label"></label>
                <select asp-for="Feedback.TeacherId" class ="form-control" asp-items="ViewBag.TeacherId" ></select>
            </div>
            <div class="form-group">
                <label asp-for="Feedback.ClassSessionId" class="control-label"></label>
                <select asp-for="Feedback.ClassSessionId" class ="form-control" asp-items="ViewBag.ClassSessionId" ></select>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Feedback.FeedbackText" class="control-label"></label>
                <input asp-for="Feedback.FeedbackText" class="form-control" aria-required="true"/>
                <span asp-validation-for="Feedback.FeedbackText" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Feedback.Rating" class="control-label"></label>
                <input asp-for="Feedback.Rating" class="form-control" />
                <span asp-validation-for="Feedback.Rating" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Feedback.FeedbackDate" class="control-label"></label>
                <input asp-for="Feedback.FeedbackDate" class="form-control" />
                <span asp-validation-for="Feedback.FeedbackDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
