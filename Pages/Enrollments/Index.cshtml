@page
@model Learner_Management_System.Pages_Enrollments.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].EnrollmentDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].CompletionDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].FinalGrade)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].Learner)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Enrollment[0].Qualification)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Enrollment) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.EnrollmentDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CompletionDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FinalGrade)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Learner.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Qualification.QualificationName)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.EnrollmentId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.EnrollmentId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.EnrollmentId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
