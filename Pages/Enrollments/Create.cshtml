            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Enrollment.QualificationId" class="control-label"></label>
                <select asp-for="Enrollment.QualificationId" class ="form-control" asp-items="ViewBag.QualificationId" aria-required="true"></select>
            </div>
            <div class="form-group">
