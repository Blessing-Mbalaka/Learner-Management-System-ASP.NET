<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Learner Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: var(--primary-color);">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Learner Management System</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Index">Dashboard</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Academic
                                </a>
                                <ul class="dropdown-menu">
                                    <li><h6 class="dropdown-header">Core Entities</h6></li>
                                    <li><a class="dropdown-item" asp-page="/Learners/Index">Learners</a></li>
                                    <li><a class="dropdown-item" asp-page="/Teachers/Index">Teachers</a></li>
                                    <li><a class="dropdown-item" asp-page="/Qualifications/Index">Qualifications</a></li>
                                    <li><a class="dropdown-item" asp-page="/Venues/Index">Venues</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header">Academic Operations</h6></li>
                                    <li><a class="dropdown-item" asp-page="/Enrollments/Index">Enrollments</a></li>
                                    <li><a class="dropdown-item" asp-page="/ClassSessions/Index">Class Sessions</a></li>
                                    <li><a class="dropdown-item" asp-page="/Assessments/Index">Assessments</a></li>
                                    <li><a class="dropdown-item" asp-page="/Grades/Index">Grades</a></li>
                                    <li><a class="dropdown-item" asp-page="/Attendances/Index">Attendance</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Administration
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Users/Index">Users</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admins/Index">Administrators</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Costs/Index">Costs</a></li>
                                    <li><a class="dropdown-item" asp-page="/QualificationCosts/Index">Qualification Costs</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Workflow
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/AssessmentBanks/Index">Assessment Banks</a></li>
                                    <li><a class="dropdown-item" asp-page="/DocumentWorkflows/Index">Document Workflows</a></li>
                                    <li><a class="dropdown-item" asp-page="/RandomizedPapers/Index">Randomized Papers</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/LearnerUploads/Index">Learner Uploads</a></li>
                                    <li><a class="dropdown-item" asp-page="/AdminUploads/Index">Admin Uploads</a></li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Feedbacks/Index">Feedback</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    @User.Identity!.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><h6 class="dropdown-header">Account</h6></li>
                                    <li>
                                        <form method="post" asp-page="/Account/Logout" class="dropdown-item">
                                            <button type="submit" class="btn btn-link text-decoration-none p-0 text-dark">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Account/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container my-4">
        @RenderBody()
    </main>

    <footer class="footer mt-auto py-3">
        <div class="container text-center">
            <span>&copy; 2026 Learner Management System. All rights reserved.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
