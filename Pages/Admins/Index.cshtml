@page
@model Learner_Management_System.Pages_Admins.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Admin[0].FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Admin[0].LastName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Admin[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Admin[0].PhoneNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Admin[0].Department)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Admin[0].HireDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Admin[0].IsActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Admin[0].Qualification)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Admin) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PhoneNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Department)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HireDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Qualification.QualificationName)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.AdminId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.AdminId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.AdminId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
