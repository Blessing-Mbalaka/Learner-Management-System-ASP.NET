@page
@model Learner_Management_System.Pages_Admins.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Admin</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Admin.AdminId" />
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Admin.QualificationId" class="control-label"></label>
                <select asp-for="Admin.QualificationId" class="form-control" asp-items="ViewBag.QualificationId" aria-required="true"></select>
                <span asp-validation-for="Admin.QualificationId" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Admin.FirstName" class="control-label"></label>
                <input asp-for="Admin.FirstName" class="form-control" aria-required="true"/>
                <span asp-validation-for="Admin.FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Admin.LastName" class="control-label"></label>
                <input asp-for="Admin.LastName" class="form-control" aria-required="true"/>
                <span asp-validation-for="Admin.LastName" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="Admin.Email" class="control-label"></label>
                <input asp-for="Admin.Email" class="form-control" aria-required="true"/>
                <span asp-validation-for="Admin.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Admin.PhoneNumber" class="control-label"></label>
                <input asp-for="Admin.PhoneNumber" class="form-control" />
                <span asp-validation-for="Admin.PhoneNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Admin.Department" class="control-label"></label>
                <input asp-for="Admin.Department" class="form-control" />
                <span asp-validation-for="Admin.Department" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Admin.HireDate" class="control-label"></label>
                <input asp-for="Admin.HireDate" class="form-control" />
                <span asp-validation-for="Admin.HireDate" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Admin.IsActive" /> @Html.DisplayNameFor(model => model.Admin.IsActive)
                </label>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
