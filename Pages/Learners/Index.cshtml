@page
@model Learner_Management_System.Pages_Learners.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Learners[0].FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Learners[0].LastName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Learners[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Learners[0].PhoneNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Learners[0].Address)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Learners[0].DateOfBirth)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Learners[0].EnrollmentDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Learners[0].IsActive)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Learners) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.FirstName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LastName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.PhoneNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateOfBirth)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EnrollmentDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.LearnerId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.LearnerId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.LearnerId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
