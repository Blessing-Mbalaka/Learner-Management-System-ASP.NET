@page
@model Learner_Management_System.Pages_AdminUploads.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>AdminUpload</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AdminUpload.UploadId" />
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="AdminUpload.AdminId" class="control-label"></label>
                <select asp-for="AdminUpload.AdminId" class="form-control" asp-items="ViewBag.AdminId" aria-required="true"></select>
                <span asp-validation-for="AdminUpload.AdminId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AdminUpload.QualificationId" class="control-label"></label>
                <select asp-for="AdminUpload.QualificationId" class="form-control" asp-items="ViewBag.QualificationId" ></select>
                <span asp-validation-for="AdminUpload.QualificationId" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="AdminUpload.FileName" class="control-label"></label>
                <input asp-for="AdminUpload.FileName" class="form-control" aria-required="true"/>
                <span asp-validation-for="AdminUpload.FileName" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="AdminUpload.FileType" class="control-label"></label>
                <input asp-for="AdminUpload.FileType" class="form-control" aria-required="true"/>
                <span asp-validation-for="AdminUpload.FileType" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AdminUpload.FileSize" class="control-label"></label>
                <input asp-for="AdminUpload.FileSize" class="form-control" />
                <span asp-validation-for="AdminUpload.FileSize" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="AdminUpload.UploadCategory" class="control-label"></label>
                <input asp-for="AdminUpload.UploadCategory" class="form-control" aria-required="true"/>
                <span asp-validation-for="AdminUpload.UploadCategory" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AdminUpload.Description" class="control-label"></label>
                <input asp-for="AdminUpload.Description" class="form-control" />
                <span asp-validation-for="AdminUpload.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
<span class="text-danger">*</span>
                <label asp-for="AdminUpload.FileData" class="control-label"></label>
                <input asp-for="AdminUpload.FileData" class="form-control" aria-required="true"/>
                <span asp-validation-for="AdminUpload.FileData" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AdminUpload.UploadDate" class="control-label"></label>
                <input asp-for="AdminUpload.UploadDate" class="form-control" />
                <span asp-validation-for="AdminUpload.UploadDate" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="AdminUpload.IsPublished" /> @Html.DisplayNameFor(model => model.AdminUpload.IsPublished)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="AdminUpload.Status" class="control-label"></label>
                <select asp-for="AdminUpload.Status" class="form-control" ></select>
                <span asp-validation-for="AdminUpload.Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AdminUpload.UploadedByUserId" class="control-label"></label>
                <select asp-for="AdminUpload.UploadedByUserId" class="form-control" asp-items="ViewBag.UploadedByUserId" ></select>
                <span asp-validation-for="AdminUpload.UploadedByUserId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
